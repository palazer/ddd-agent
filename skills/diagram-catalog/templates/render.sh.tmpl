#!/usr/bin/env bash
#
# 0-diagrams/render.sh — render all Mermaid diagrams in this folder to SVG.
# Generated by /ddd:diagrams. Edit freely; the skill will not overwrite.
#
# Usage:
#   ./render.sh                # render every .md (skipping README.md, BACKLOG.md)
#   ./render.sh 03             # render only files whose basename starts with "03"
#   ./render.sh --check        # dry-run: list what would be rendered
#
# Implementation:
#   - Uses `npx @mermaid-js/mermaid-cli` (mmdc). Lazily installed on first run.
#   - Each .md may contain multiple Mermaid blocks. mmdc emits files
#     suffixed -1.svg, -2.svg, ... in the order they appear.
#   - Files with a single block are renamed from <stem>-1.svg to <stem>.svg.
#   - Set MMDC_PUPPETEER_CONFIG to a custom puppeteer config if your CI/sandbox
#     environment needs it (e.g. {"args":["--no-sandbox"]}).

set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$DIR"

FILTER=""
DRY_RUN=false

for arg in "$@"; do
  case "$arg" in
    --check) DRY_RUN=true ;;
    -*)      echo "unknown flag: $arg" >&2; exit 1 ;;
    *)       FILTER="$arg" ;;
  esac
done

PUPPETEER_FLAG=""
if [[ -n "${MMDC_PUPPETEER_CONFIG:-}" ]]; then
  PUPPETEER_FLAG="--puppeteerConfigFile $MMDC_PUPPETEER_CONFIG"
fi

echo "→ Rendering Mermaid → SVG in $DIR"
[[ "$DRY_RUN" == true ]] && echo "  (dry-run; no files will be written)"

for md in *.md; do
  case "$md" in
    README.md|BACKLOG.md) continue ;;
  esac

  if [[ -n "$FILTER" && "$md" != "$FILTER"* ]]; then
    continue
  fi

  stem="${md%.md}"
  echo "  · $md"

  if [[ "$DRY_RUN" == true ]]; then
    continue
  fi

  # mmdc emits <stem>-<n>.svg per Mermaid block.
  npx -y @mermaid-js/mermaid-cli mmdc \
    -i "$md" \
    -o "${stem}.svg" \
    $PUPPETEER_FLAG \
    --quiet 2>/dev/null || {
      echo "    ! mmdc failed for $md (continuing with next file)" >&2
      continue
    }

  # Single-block .md produces <stem>-1.svg; rename to <stem>.svg for cleanliness.
  if [[ -f "${stem}-1.svg" && ! -f "${stem}-2.svg" ]]; then
    mv "${stem}-1.svg" "${stem}.svg"
  fi
done

echo "✓ Done. SVGs in $DIR"
echo ""
echo "Tips:"
echo "  - GitHub renders Mermaid in .md files natively (no SVG needed for browsing)."
echo "  - Use Kroki (https://kroki.io) for batch HTTP rendering in CI."
echo "  - For Excalidraw-style pictographs (e.g. T4.3 Domain Storytelling), this script"
echo "    only produces a Mermaid approximation. Hand-illustrate for partner-facing decks."
