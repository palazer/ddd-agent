# Reference clones of upstream OSS assets — not part of this repo
vendor/

# Per-project working artifacts (ubiquitous-language, event storms, canvases, ADRs)
# Keep the directory, ignore contents (except .gitkeep)
projects/*
!projects/.gitkeep

# OS / editor noise
.DS_Store
.idea/
.vscode/
*.swp
*~

# Claude Code local session state — and dev-time .claude/ symlinks for
# in-repo testing (the canonical plugin layout lives at root: agents/,
# skills/, commands/). Never commit .claude/ — keeping it out is what
# makes the v1.0.1 plugin-root layout the single source of truth.
.claude/

# Defensive — environment files, build artifacts, logs
.env
.env.*
*.log
node_modules/
